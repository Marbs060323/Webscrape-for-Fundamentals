# Local environment for starlink_scraper
# Set the browser to use for scraping: firefox, chrome, or edge
STARLINK_BROWSER=firefox

# Optional: path to your browser profile (Firefox profile folder or Chrome/Edge user-data-dir)
# Examples:
# Firefox: C:\Users\you\AppData\Roaming\Mozilla\Firefox\Profiles\xxxxxxxx.default
# Chrome:  C:\Users\you\AppData\Local\Google\Chrome\User Data\Profile 1
STARLINK_PROFILE_PATH=C:\Users\yusof\AppData\Roaming\Mozilla\Firefox\Profiles\yi8njs1u.StarlinkProfile
